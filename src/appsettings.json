{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning",
			"Microsoft.AspNetCore.Authentication": "Debug"
		}
	},
	"AllowedHosts": "*",
	"Jwt": {
		"Secret": "aVeryLongSecretKeyThatIsAtLeast32BytesLong",
		"Audience": "api"
	},
	"Kestrel": {
		"Endpoints": {
			"HttpsInlineCertFile": {
				"Url": "https://localhost:5001",
				"Protocols": "Http2",
				"Certificate": {
					"Path": "../cert.pfx",
					"Password": "testpassword"
				}
			}
		}
	}
}
